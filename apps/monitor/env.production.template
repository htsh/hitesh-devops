# Monitor production environment template
# Copy to .env on vps3 and fill in values

NODE_ENV=production
PORT=3100
HOST=0.0.0.0

# MongoDB — local instance on vps3
MONGO_URI=mongodb://localhost:27017/monitor

# ntfy notifications
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=hitesh-monitor

# SSH hosts (Tailscale IPs)
SSH_HOST_vps1=100.64.0.1
SSH_HOST_vps2=100.64.0.2
SSH_HOST_vps3=127.0.0.1
